# ============================================================
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# Mode simulation paiement (true = fausse page SATIM, false = vrai SATIM)
SATIM_MOCK_MODE=true
NEXT_PUBLIC_SATIM_MOCK_MODE=true

# Mode test SATIM (true = test.satim.dz | false = epg.satim.dz production)
SATIM_TEST_MODE=true

# Identifiants SATIM — obtenus lors de l'activation
SATIM_USERNAME=
SATIM_PASSWORD=
SATIM_TERMINAL_ID=

# URL publique de votre site (sans slash final)
# En local avec ngrok : https://xxxx.ngrok-free.app
# En production : https://votre-domaine.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>

# Google reCAPTCHA v2 — https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Facturation — informations affichées sur la facture PDF
COMPANY_NAME=CIB Shop
COMPANY_ADDRESS=Algérie

# Resend — envoi de la facture par email — https://resend.com
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=factures@votre-domaine.com
